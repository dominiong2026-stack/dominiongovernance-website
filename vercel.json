{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/frameworks/", "destination": "/frameworks", "permanent": false }
  ],
  "headers": [
    {
      "source": "/request",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" }
      ]
    },
    {
      "source": "/request/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" }
      ]
    },
    {
      "source": "/api/request-review",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/frameworks", "destination": "/frameworks.html" },
    { "source": "/frameworks/", "destination": "/frameworks.html" },
    { "source": "/frameworks/ai-exposure-map", "destination": "/frameworks/ai-exposure-map/index.html" },
    { "source": "/frameworks/ai-exposure-map/", "destination": "/frameworks/ai-exposure-map/index.html" },
    { "source": "/trust-centre/evidence-standard", "destination": "/trust-centre/evidence-standard/index.html" },
    { "source": "/trust-centre/evidence-standard/", "destination": "/trust-centre/evidence-standard/index.html" },
    { "source": "/trust-centre/professional-boundaries", "destination": "/trust-centre/professional-boundaries/index.html" },
    { "source": "/trust-centre/professional-boundaries/", "destination": "/trust-centre/professional-boundaries/index.html" },
    { "source": "/trust-centre/confidentiality-document-handling", "destination": "/trust-centre/confidentiality-document-handling/index.html" },
    { "source": "/trust-centre/confidentiality-document-handling/", "destination": "/trust-centre/confidentiality-document-handling/index.html" },
    { "source": "/trust-centre/cookies-notice", "destination": "/trust-centre/cookies-notice/index.html" },
    { "source": "/trust-centre/cookies-notice/", "destination": "/trust-centre/cookies-notice/index.html" },
    { "source": "/privacy", "destination": "/trust-centre/privacy-notice/index.html" },
    { "source": "/terms", "destination": "/trust-centre/terms-of-use/index.html" },
    { "source": "/cookies", "destination": "/trust-centre/cookies-notice/index.html" },
    { "source": "/cookies.html", "destination": "/trust-centre/cookies-notice/index.html" }
  ]
}