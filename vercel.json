{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/frameworks", "destination": "/frameworks.html" },
    { "source": "/privacy", "destination": "/trust-centre/privacy-notice/index.html" },
    { "source": "/terms", "destination": "/trust-centre/terms-of-use/index.html" },
    { "source": "/cookies", "destination": "/cookies.html" }
  ]
}
